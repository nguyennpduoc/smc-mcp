# Cysic AI (MiniMax M3) configuration — REQUIRED
# Get your API key from Cysic and paste it below. Never commit this file.
CYSIC_API_KEY=your-cysic-api-key-here

# Optional: override the API base URL
# CYSIC_BASE_URL=https://token-ai.cysic.xyz/v1

# Optional: override the model id
# CYSIC_MODEL=minimax-m3

# Optional: HTTP timeout in ms (default 30000)
# CYSIC_TIMEOUT_MS=30000

# Optional: max retry attempts on 429/5xx (default 3)
# CYSIC_MAX_RETRIES=3

# Optional: base backoff in ms (default 500)
# CYSIC_BACKOFF_MS=500
